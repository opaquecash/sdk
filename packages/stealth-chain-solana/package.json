    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opaquecash/adapter": "0.1.0",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@solana/web3.js": "^1.98.4"
  },
  "sideEffects": false
}
