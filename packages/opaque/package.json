    "@opaquecash/deployments": "0.2.1",
    "@opaquecash/psr-chain": "0.2.1",
    "@opaquecash/psr-chain-solana": "0.2.1",
    "@opaquecash/psr-core": "0.2.1",
    "@opaquecash/psr-prover": "0.2.1",
    "@opaquecash/stealth-balance": "0.2.0",
    "@opaquecash/stealth-chain": "0.2.3",
    "@opaquecash/stealth-chain-solana": "0.2.0",
    "@opaquecash/stealth-core": "0.2.0",
    "@opaquecash/stealth-wasm": "0.2.1",
    "@opaquecash/uab": "0.2.1",
